# Dashboard → ML API (when running API on host port 8000)
INSUREGUARD_API_URL=http://127.0.0.1:8000/predict
INSUREGUARD_HEALTH_URL=http://127.0.0.1:8000/health

# Where the API loads fraud_model.pkl, registry, parquet, etc. (default: ./artifacts next to main.py)
# INSUREGUARD_ARTIFACT_DIR=/absolute/or/relative/path/to/artifacts

# Optional timeouts (seconds)
# INSUREGUARD_REQUEST_TIMEOUT_S=120

# Compose / in-network service names — use these when dashboard and API share a Docker network:
# INSUREGUARD_API_URL=http://api:8000/predict
# INSUREGUARD_HEALTH_URL=http://api:8000/health
